# ── Discord ───────────────────────────────────────────────────────
# Discord Developer Portal > 앱 > General Information
DISCORD_APPLICATION_ID=123456789012345678
DISCORD_PUBLIC_KEY=abcdef1234567890...

# 슬래시 커맨드 등록(register_commands.py)에만 사용, 런타임 불필요
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# 일일 결산 메시지를 보낼 채널 웹훅 (채널 편집 → 연동 → 웹훅)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxx/yyyyy

# ── Supabase ──────────────────────────────────────────────────────
# Supabase 프로젝트 대시보드 > Settings > API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ── GitHub ────────────────────────────────────────────────────────
# 없으면 API 60req/h 제한, 있으면 5000req/h
# Settings → Developer settings → Personal access tokens (read:user 권한)
GH_TOKEN=

# ── 봇 설정 ──────────────────────────────────────────────────────
FINE_AMOUNT=1000
