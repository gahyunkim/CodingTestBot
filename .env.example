# Discord 봇 토큰 (Discord Developer Portal > Bot > Token)
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# 커밋 알림용 Discord 웹훅 URL (채널 편집 → 연동 → 웹훅에서 생성)
# 새 멤버 온보딩 메시지에 자동으로 포함됩니다
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxx/yyyyy

# 알림을 보낼 Discord 채널 ID (채널 우클릭 → "ID 복사")
DISCORD_CHANNEL_ID=123456789012345678

# GitHub Personal Access Token (없어도 되지만 있으면 API 한도가 높아짐)
# github.com → Settings → Developer settings → Personal access tokens → Generate new token
# 권한: read:user, read:org 체크
GITHUB_TOKEN=

# 하루 벌금 금액 (원)
FINE_AMOUNT=1000
